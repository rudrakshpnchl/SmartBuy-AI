# Copy this file to backend/.env and fill in your values.
# The backend loads this file automatically on startup.
# SERPAPI_API_KEY enables live Google Shopping search.
# If GEMINI_API_KEY is left blank, the system uses rule-based AI fallback.
# USD_TO_INR_RATE is optional; it controls how source USD prices are converted
# before they are returned by the API and shown in the frontend.
# History, feed, and personalized suggestions need Firebase Admin credentials.
# Provide either GOOGLE_APPLICATION_CREDENTIALS or FIREBASE_SERVICE_ACCOUNT_JSON.

SERPAPI_API_KEY=
GEMINI_API_KEY=your_gemini_api_key_here
SERPAPI_GL=in
SERPAPI_HL=en
USD_TO_INR_RATE=92.40
GOOGLE_APPLICATION_CREDENTIALS=serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT_JSON=
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5000